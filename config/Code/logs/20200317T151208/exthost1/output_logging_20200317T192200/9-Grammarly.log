2020-03-17T18:35:01.175Z grammarly:host 🔻 {
  point: 'DoubleNegative',
  transforms: [ "<span class='gr_grammar_del'>not</span>" ],
  title: 'Double negative',
  minicardTitle: 'Rewrite the sentence',
  result: '',
  details: '<p>A double negative is formed when two words in a sentence are negative. One negates the other, resulting in a positive meaning. Negativity is expressed by adding the word not (<i>he is not, they aren’t</i>), by using a negative word (<i>never, no, neither, nowhere</i>), or by adding a negative prefix to a positive word (<i>common/uncommon, approve/disapprove</i>). In general, the double negative is considered non-standard usage, especially in formal writing. For a negative meaning, use only one negative word.\n',
  explanation: "<p>Your sentence appears to include a double negative with the inclusion of both <b>n't</b> and <b>not</b>. Remove a negative word, or make certain you intend to have the positive result.\n",
  examples: '<p><span class="red">Incorrect: She has<b>n’t</b> talked to <b>nobody</b>. (This means she has talked to someone.)</span><br/><span class="green">Correct: She has<b>n’t</b> talked to anybody.</span><br/><span class="green">Correct: She has talked to <b>nobody</b>.</span><br/><p><span class="red">Incorrect: <b>Never</b> give him <b>no</b> peanuts. He is allergic.</span><br/><span class="green">Correct: <b>Never</b> give him <b>any</b> peanuts. He is allergic.</span><br/><span class="green">Correct: Give him <b>no</b> peanuts. He is allergic.</span><br/>',
  todo: 'rewrite the sentence',
  handbookLink: '',
  sentence_no: 0,
